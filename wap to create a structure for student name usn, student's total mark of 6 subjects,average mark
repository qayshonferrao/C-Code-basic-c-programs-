#include<stdio.h>
struct student{
    
    char name[30];
    char USN[20];
    float marks[6];
    float total;
    float avg;
};

int main(){
    struct student s;
    int i;
    
    printf("Enter Student Name:");
    scanf("%s",s.name);
    
    printf("Enter USN:\n");
    scanf("%s",s.USN);
    
    s.total=0;
    
    printf("Enter marks of 6 subjects:\n");
    for(i=0;i<6;i++){
        scanf("%f",&s.marks[i]);
        s.total=s.total+s.marks[i];
    }
    
    s.avg=s.total/6.0;
    
     printf("\n----- Student Details -----\n");
    printf("Name: %s\n", s.name);
    printf("USN: %s\n", s.USN);
    printf("Total Marks: %.2f\n", s.total);
    printf("Average Marks: %.2f\n", s.avg);

    return 0;
}
