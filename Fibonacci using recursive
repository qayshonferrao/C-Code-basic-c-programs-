#include<stdio,h>

int fibo(int n);

int main()
{
    int i,n;
    
    printf("Enter number of terms needed:");
    scanf("%d",&n);
    
    printf("Fibonacci Series:\n");
    
    for(i=0;i<n;i++){
        printf("%d\t",fibo(i));
        
    }
    return 0;
}
int fibo(int n)
{
    if(n==1){
        return 0;
    }
    else if(n==2){
        return 1;
    }
    else{
        return fibo(n-1)+fibo(n-2);
    }
}
