#include<stdio.h>
#include<stdlib.h>

int main()
{
    int *ptr;
    
    ptr=(int*)malloc(1*sizeof(int));
    
    if (ptr==NULL)
    {
        printf("Memory allocation failed\n");
        return 1;
    }
    
    print("Address of first byte=%p\n",(void*)ptr);
    
    free(ptr);
    
    return 0;
}
