#include<stdio.h>
#include<stdlib.h>

int main()
{
    int *ptr, n,i,sum=0;
    
    printf("Enter number of elements");
    scanf("%d",&n);
    
    ptr=(int*)malloc(n*sizeof(int));
    
    if(ptr==NULL){
        printf("Memory allocation failed\n");
        return 1;
    }
    
    printf("Enter %d values:\n",n);
    for(i=0;i<n;i++){
        scanf("%d",&ptr[i]);
        sum= sum+ptr[i];
    }
    
    printf("Sum=%d\n",sum);
   
    free(ptr);
    return 0;
    
}
