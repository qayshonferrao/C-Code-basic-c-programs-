int main()
{
    int n;
    printf("Enter any non-negative integer:");
    scanf("%d",&n);
    
    if(n<0){
        printf("Invalid Input");
    }
    else{
        printf("The Factorial of %d is:%d\n",n,fact(n));
        
    }
    return 0;
}

int fact(int n)
{
    if(n==0){
        return 1;
    }
    else{
        return n*fact(n-1);
    }

}
