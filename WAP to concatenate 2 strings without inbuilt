#include<stdio.h>
int main(){
    int i=0,j=0;
    char str1[100],str2[100];
    
    printf("Enter first string:");
    scanf("%s", str1);
    
    printf("Enter second string:");
    scanf("%s",str2);
    
    //movin i to end of first str
    while(str1[i]!='\0'){
        i++;
    }
    
    //coping and appending
    while(str2[j]!='\0'){
        str1[i]=str2[j];
        i++;
        j++;
    }
    
    str1[i]='\0';
    
    printf("Concatenated string:%s\n",str1);
    
    return 0;
}
