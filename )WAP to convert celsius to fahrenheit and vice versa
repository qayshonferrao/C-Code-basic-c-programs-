#include<stdio.h>
int main(){
  float C,F;
  int choice;

  printf("1.Convert Celsius to fahrenheit\\n2.Convert Fahrenheit to Celsius\\n");
  printf("Enter your choice(1/2):");
  scanf("%d",&choice);

  if(choice==1){
    printf("Enter the degree in celsius:");
    scanf("%f",&C);

    F=(C*9/5)+32;
    printf("The given Temperature in Fahrenheit is:%2.f\\n",F);

  }
  else if(choice==2){
    printf("Enter the temperature in Fahrenheit:");
    scanf("%f",&F);

    C=(F-32)*5/9;
    printf("The given temp in celsius is:%2.f\\n",C);
  }
  else{
    printf("Invalid choice!");
  }
return 0;
}

